{
  "name": "thai-accounting-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3015 | xargs -r kill -9; rm -rf .next; NODE_OPTIONS='--dns-result-order=ipv4first' next dev --turbopack -p 3015",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev -u http://localhost:3015/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "vitest run --config vitest.config.db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seeds/run.ts",
    "benchmark": "tsx benchmarks/run-benchmark.ts",
    "benchmark:extraction": "tsx benchmarks/extraction-comparison.ts",
    "test:pdf": "tsx scripts/test-pdf-parser.ts",
    "validate:pdf-thai": "tsx scripts/validate-react-pdf-thai.tsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:vercel": "BASE_URL=https://thai-accounting-app.vercel.app playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.5",
    "@neondatabase/serverless": "^1.0.2",
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.43.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/blob": "^2.3.1",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "inngest": "^3.52.6",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pdf-to-img": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^15.0.0",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "svix": "^1.88.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@sentry/cli",
      "sharp",
      "protobufjs",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.8",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
